@using Shop.Data.Models
@model IEnumerable<Categorys>
@{
	Layout = "_Layout";
}
<form>
	<div>
		Наименование:
		<br /><input name="name" placeholder="наименование:"/>
	</div>
	<div>
		Описание:
		<br/><input name="descript" placeholder="Описание:"/>
	</div>
	<div>
		<label for="file">Изображение</label>
		<br /><input name="files" type="file"/>
	</div>
	<div>
		Стоимость:
		<br /><input name="price"/>
	</div>
	<div>
		Категория:
		<br/><select name="idCategory">
			@{
				foreach(var Category in Model){
					<option	value="@Category.Id">@Category.Name</option>
				}
			}
		</select>
	</div>
	<input type="submit"/>
</form>