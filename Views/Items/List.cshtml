@model IEnumerable<Shop.Data.Models.Items>

<h2>Все автомобили</h2>
<div class="row mt-5 mb-2">
    @if (Model != null)
    {
        foreach (var car in Model)
        {
            <div>
                <h3>Модель: @car.Name</h3>
                <p>Цена: @car.Price.ToString("c")</p>
                @* Ошибка часто здесь: если Category == null, обращение к .Name вызовет Exception *@
                <p>Категория: @(car.Category?.Name ?? "Не указана")</p>
            </div>
        }
    }
    else
    {
        <p>Данные не загружены. Проверьте инициализацию Mock-объектов.</p>
    }
</div>