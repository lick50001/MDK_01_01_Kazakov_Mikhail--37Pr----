@using Shop.Data.ViewModels
@model VMItems
@{
    ViewData["Title"] = "Все предметы";
    Layout = "_Layout";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

<div class="sort-container mb-4">
    <label for="sortPrice">Сортировка по цене:</label>
    <select id="sortPrice" onchange="sortByPrice(this)">
        <option value="0">По умолчанию</option>
        <option value="1">Дешевле</option>
        <option value="2">Дороже</option>
    </select>

    <a href="/Items/Add" class="btn-add">Добавить товар</a>
</div>

@if (!string.IsNullOrEmpty(ViewBag.SearchString))
{
    <div class="alert alert-info">
        Результаты поиска: "@ViewBag.SearchString" - найдено @ViewBag.SearchResult товаров
        <a href="/Items/List">Сбросить поиск</a>
    </div>
}

<h2 class="mb-4">Все предметы</h2>

<div class="row g-4" id="itemsContainer">
    @if (Model.Items != null && Model.Items.Any())
    {
        @foreach (var item in Model.Items)
        {
            <div class="col-item item"
                 data-price="@item.Price"
                 data-id="@item.Id">
                <div class="car-card">
                    <div class="image-container">
                        @if (!string.IsNullOrEmpty(item.Img))
                        {
                            <img src="/img/@item.Img" alt="@item.Name" class="car-image" />
                        }
                        else
                        {
                            <img src="~/img/no-image.png" alt="Нет фото" class="car-image" />
                        }
                    </div>
                    <div class="content">
                        <h3>@item.Name</h3>
                        <div class="price">@item.Price.ToString("C")</div>
                        <div class="category">
                            @(item.Category?.Name ?? "Не указана")
                        </div>
                        <div class="description">
                            @item.Description
                        </div>

                        <div class="action-buttons">
                            <a href="/Items/Update/@item.Id" class="btn-Update">Редактировать</a>
                            <a href="/Items/Delete/@item.Id" class="btn-delete">Удалить</a>
                        </div>

                        <div class="basket">
                            <div class="button add-to-cart" data-idItem="@item.Id">
                                В корзину
                            </div>
                            <div class="count">
                                <div class="button min">-</div>
                                <div class="text">1</div>
                                <div class="button max">+</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12">
            <p>Нет предметов для отображения.</p>
        </div>
    }
</div>

@section Scripts {
    <script>
        // Кнопка "В корзину"
        $(".item").on("click", ".basket .button.add-to-cart", function () {
            var $btn = $(this);
            var $basket = $btn.closest(".basket");
            $basket.children(".count").show();
            $btn.hide();

            $.ajax({
                url: '@Url.Action("Basket", "Items")',
                type: "POST",
                data: { idItem: $btn.attr("data-idItem") },
                dataType: "json",
                success: SuccessBasket,
                error: AjaxError
            });
        });

        // Кнопка "-"
        $(".item").on("click", ".count .min", function () {
            var $count = $(this).closest(".count");
            var $textEl = $count.children(".text");
            var idItem = $(this).closest(".item").attr("data-id");
            var count = parseInt($textEl.text()) - 1;

            if (count <= 0) {
                $count.hide();
                $count.siblings(".add-to-cart").show();
            } else {
                $textEl.text(count);
            }

            $.ajax({
                url: '@Url.Action("BasketCount", "Items")',
                type: "POST",
                data: { idItem: idItem, count: count },
                dataType: "json",
                success: SuccessBasket,
                error: AjaxError
            });
        });

        // Кнопка "+"
        $(".item").on("click", ".count .max", function () {
            var $textEl = $(this).closest(".count").children(".text");
            var idItem = $(this).closest(".item").attr("data-id");
            var count = parseInt($textEl.text()) + 1;
            $textEl.text(count);

            $.ajax({
                url: '@Url.Action("BasketCount", "Items")',
                type: "POST",
                data: { idItem: idItem, count: count },
                dataType: "json",
                success: SuccessBasket,
                error: AjaxError
            });
        });

        function updateBasketCount() {
            $.ajax({
                url: '@Url.Action("BasketTotal", "Items")',
                type: "GET",
                success: function (total) {
                    $("#basketCount").text(total);
                }
            });
        }

        function SuccessBasket(data) {
            updateBasketCount();
        }

        function AjaxError() {
            console.log("Ошибка выполнения ajax");
        }

        $(document).ready(function () {
            updateBasketCount();

            $('.search').on('keypress', function(e) {
                if (e.which === 13) {
                    var searchString = $(this).val();
                    window.location.href = '/Items/List?searchString=' + encodeURIComponent(searchString);
                }
            });
        });

        function sortByPrice(sender) {
            const sortValue = sender.value;
            const container = document.getElementById('itemsContainer');
            const items = Array.from(container.querySelectorAll('.item'));

            if (sortValue === '1') {
                items.sort((a, b) => parseFloat(a.dataset.price) - parseFloat(b.dataset.price));
            } else if (sortValue === '2') {
                items.sort((a, b) => parseFloat(b.dataset.price) - parseFloat(a.dataset.price));
            } else {
                items.sort((a, b) => parseInt(a.dataset.id) - parseInt(b.dataset.id));
            }

            while (container.firstChild) container.removeChild(container.firstChild);
            items.forEach(item => container.appendChild(item));
        }
    </script>
}