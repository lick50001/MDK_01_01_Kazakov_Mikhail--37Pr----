@using Shop.Data.Models
@model Items
@{
    Layout = "_Layout";
    ViewData["Title"] = "Редактирование товара";
}

<h2>Редактирование товара</h2>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

<div class="card">
    <div class="card-body">
        <form method="post" enctype="multipart/form-data" asp-action="Update" asp-controller="Items">
            <input type="hidden" name="id" value="@Model.Id" />

            <div class="form-group">
                <label>Наименование:</label>
                <input type="text" class="form-control" name="name" value="@Model.Name" required />
            </div>

            <div class="form-group">
                <label>Описание:</label>
                <textarea class="form-control" name="descr" rows="3">@Model.Description</textarea>
            </div>

            <div class="form-group">
                <label>Цена:</label>
                <input type="number" class="form-control" name="price" value="@Model.Price" step="0.01" required />
            </div>

            <div class="form-group">
                <label>Изображение:</label>
                @if (!string.IsNullOrEmpty(Model.Img) && Model.Img != "no-image.png")
                {
                    <div>
                        <img src="/img/@Model.Img" alt="Текущее изображение" style="max-height: 100px;" />
                        <p><small>Текущее изображение</small></p>
                    </div>
                }
                <input type="file" class="form-control" name="files" accept="image/*" />
                <small>Оставьте пустым, чтобы сохранить текущее изображение</small>
            </div>

            <div class="form-group">
                <label>Категория:</label>
                <select class="form-control" name="idCategory" required>
                    <option value="">Выберите категорию</option>
                    @{
                        var categories = ViewBag.Categories as IEnumerable<Categorys>;
                        if (categories != null)
                        {
                            foreach (var cat in categories)
                            {
                                if (Model.Category != null && cat.Id == Model.Category.Id)
                                {
                                    <option value="@cat.Id" selected>@cat.Name</option>
                                }
                                else
                                {
                                    <option value="@cat.Id">@cat.Name</option>
                                }
                            }
                        }
                    }
                </select>
            </div>

            <button type="submit" class="btn-save">Сохранить</button>
            <a href="/Items/List" class="btn-cancel">Отмена</a>
        </form>
    </div>
</div>